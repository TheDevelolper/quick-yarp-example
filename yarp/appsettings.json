{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "weather-route": {
        "ClusterId": "weather-cluster",
        "Match": {
          "Path": "/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "weather-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "api1": {
            "Address": "https://localhost:7700/"
          },
          "api2": {
            "Address": "https://localhost:7701/"
          },
          "api3": {
            "Address": "https://localhost:7702/"
          },
          "api4": {
            "Address": "https://localhost:7703/"
          },
          "api5": {
            "Address": "https://localhost:7704/"
          },
          "api6": {
            "Address": "https://localhost:7705/"
          },
          "api7": {
            "Address": "https://localhost:7706/"
          },
          "api8": {
            "Address": "https://localhost:7707/"
          },
          "api9": {
            "Address": "https://localhost:7708/"
          },
          "api10": {  
            "Address": "https://localhost:7709/" 
          }
        }
      }
    }
  }
}

